<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/mascot" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="150dp"
        android:gravity="center"
        android:orientation="vertical">

        <Button
            android:id="@+id/viewFlashcardBtn"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_button"
            android:elevation="8dp"
            android:text="VIEW FLASHCARDS"
            android:textSize="18dp" />

        <Button
            android:id="@+id/studyModesBtn"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_button"
            android:elevation="8dp"
            android:text="STUDY MODES"
            android:textSize="18dp" />

        <Button
            android:id="@+id/filterSortBtn"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_button"
            android:elevation="8dp"
            android:text="FILTER &amp; SORT"
            android:textSize="18dp" />

        <Button
            android:id="@+id/statisticsBtn"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_button"
            android:elevation="8dp"
            android:text="STATISTICS"
            android:textSize="18dp" />

        <Button
            android:id="@+id/settingsBtn"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_button"
            android:elevation="8dp"
            android:text="SETTINGS"
            android:textSize="18dp" />

    </LinearLayout>
</RelativeLayout>

